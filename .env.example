COPILOT_INTERCEPT_AUTH_TOKEN=
COPILOT_INTERCEPT_TIMEOUT_MS=5000
COPILOT_INTERCEPT_FAIL_OPEN=false
COPILOT_INTERCEPT_POLL_INTERVAL_MS=1000
COPILOT_INTERCEPT_MAX_WAIT_MS=30000

GIT_ENABLED=true
GIT_WORK_DIR=
GIT_TIMEOUT_MS=30000
