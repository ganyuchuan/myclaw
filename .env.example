PORT=18789
GATEWAY_TOKEN=dev-token
LLM_PROVIDER=openai
LLM_PROTOCOL=responses
LLM_ENDPOINT=https://api.openai.com/v1/responses
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=
LLM_STREAM=false

FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
