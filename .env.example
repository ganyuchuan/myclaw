FEISHU_CLIENT_ID=myclaw-feishu-bridge
FEISHU_REQUEST_TIMEOUT_MS=15000
FEISHU_IMAGE_TEMP_DIR=data/feishu-images
FEISHU_IMAGE_MAX_BYTES=10485760
FEISHU_FILE_TEMP_DIR=data/feishu-files
