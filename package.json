{
  "name": "myclaw",
  "version": "0.1.0",
  "private": true,
  "description": "MVP Gateway for MyClaw",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json --noCheck",
    "postbuild": "mkdir -p dist/sync && cp src/sync/intercept-approval.html dist/sync/intercept-approval.html",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "npm run build && node dist/index.js",
    "dev": "tsc --watch -p tsconfig.json",
    "bridge:feishu": "npm run build && node dist/bridge/feishu.js",
    "sync-server": "npm run build && node dist/sync/http-server.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "pm2": "^6.0.14",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
